<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chipax - Editor de Help Center</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Inter, system-ui, sans-serif; background: #f1f5f9; color: #1e293b; min-height: 100vh; }
  .topbar { background: #1e293b; color: #fff; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
  .topbar h1 { font-size: 16px; font-weight: 700; }
  .topbar span { font-size: 12px; color: #94a3b8; }
  .container { max-width: 820px; margin: 32px auto; padding: 0 16px 60px; }
  .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 20px; margin-bottom: 16px; }
  .card h2 { font-size: 13px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 12px; }
  label { font-size: 14px; font-weight: 600; display: block; margin-bottom: 6px; }
  input, textarea { width: 100%; padding: 9px 12px; border: 1px solid #cbd5e1; border-radius: 7px; font-size: 14px; font-family: inherit; color: #1e293b; background: #f8fafc; resize: vertical; }
  input:focus, textarea:focus { outline: 2px solid #3b82f6; border-color: transparent; background: #fff; }
  .row { display: flex; gap: 10px; }
  .row > div { flex: 1; }
  .btn-primary { background: #1e293b; color: #fff; width: 100%; font-size: 15px; padding: 13px; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; }
  .btn-primary:disabled { opacity: .5; cursor: not-allowed; }
  .btn-save { background: #3b82f6; color: #fff; font-size: 13px; padding: 8px 18px; border-radius: 7px; border: none; cursor: pointer; }
  .btn-publish { background: #1e293b; color: #fff; font-size: 12px; padding: 5px 14px; border-radius: 6px; border: none; cursor: pointer; margin-left: auto; }
  .alert { border-radius: 7px; padding: 11px 14px; font-size: 13px; margin-bottom: 14px; }
  .alert-error { background: #fee2e2; color: #dc2626; }
  .alert-success { background: #dcfce7; color: #15803d; }
  .step-msg { font-size: 13px; color: #64748b; margin-top: 8px; text-align: center; min-height: 20px; }
  .tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
  .tab { padding: 6px 13px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; background: #e2e8f0; color: #475569; }
  .tab.active { background: #1e293b; color: #fff; }
  .art-header { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 8px; }
  .art-title { font-weight: 700; font-size: 15px; }
  .badge { padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
  .badge-updated { background: #dcfce7; color: #15803d; }
  .badge-partial { background: #fef9c3; color: #854d0e; }
  .badge-none { background: #f1f5f9; color: #64748b; }
  .art-meta { font-size: 13px; color: #64748b; margin-bottom: 10px; }
  .changes-list { margin: 8px 0 12px 18px; }
  .changes-list li { font-size: 13px; margin-bottom: 3px; }
  .version-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 7px; padding: 14px; white-space: pre-wrap; font-size: 13px; line-height: 1.7; color: #334155; margin-top: 6px; }
  .art-sep { border: none; border-top: 1px solid #e2e8f0; margin: 20px 0; }
  .text-result { white-space: pre-wrap; font-size: 14px; line-height: 1.75; color: #334155; }
  .keys-ok { font-size: 12px; color: #10b981; }
  .keys-missing { font-size: 12px; color: #ef4444; }
</style>
</head>
<body>

<div class="topbar">
  <h1>Chipax - Editor de Help Center</h1>
  <span>Actualizacion masiva de articulos Intercom</span>
</div>

<div class="container">

  <div class="card">
    <h2>Credenciales</h2>
    <div class="row" style="margin-bottom:10px">
      <div>
        <label>API Key de Anthropic</label>
        <input type="password" id="anthropic-key" placeholder="sk-ant-..."/>
      </div>
      <div>
        <label>Token de Intercom</label>
        <input type="password" id="intercom-token" placeholder="Token de acceso..."/>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px">
      <button class="btn-save" onclick="saveKeys()">Guardar credenciales</button>
      <span id="keys-status" class="keys-missing">No configuradas</span>
    </div>
    <p style="font-size:12px;color:#94a3b8;margin-top:8px">Se guardan solo en tu navegador. No se envian a ningun servidor externo.</p>
  </div>

  <div class="card">
    <h2>Cambio a aplicar</h2>
    <label>Descripcion del cambio</label>
    <textarea id="cambio" rows="4" placeholder="Ej: El boton Registrar pago ahora se llama Agregar cobro en todos los modulos."></textarea>
    <label style="margin-top:14px">Referencias adicionales (opcional)</label>
    <textarea id="referencia" rows="3" placeholder="Contexto extra: textos nuevos de la UI, notas sobre imagenes, restricciones de plan, lineamientos de redaccion."></textarea>
  </div>

  <div id="alert-box"></div>
  <button class="btn-primary" id="main-btn" onclick="run()">Buscar articulos y analizar cambios</button>
  <p class="step-msg" id="step-msg"></p>

  <div id="resultado" style="display:none;margin-top:32px">
    <h2 style="font-size:17px;font-weight:700;margin-bottom:14px">Resultado del analisis</h2>
    <div class="tabs" id="tabs"></div>
    <div class="card" id="tab-content"></div>
  </div>

</div>

<script>
var SECTIONS = ["aprobacion", "resumen", "criterio", "articulos", "consistencia", "riesgos"];
var LABELS = {
  resumen: "1. Resumen",
  criterio: "2. Criterio",
  aprobacion: "3. Para aprobacion",
  articulos: "4. Por articulo",
  consistencia: "5. Consistencia",
  riesgos: "6. Riesgos"
};
var resultado = null;
var activeSection = "aprobacion";

function saveKeys() {
  var ak = document.getElementById("anthropic-key").value.trim();
  var it = document.getElementById("intercom-token").value.trim();
  if (!ak || !it) { showAlert("Ingresa ambas credenciales.", "error"); return; }
  localStorage.setItem("chipax_ak", ak);
  localStorage.setItem("chipax_it", it);
  updateKeysStatus();
  showAlert("Credenciales guardadas.", "success");
}

function getKeys() {
  return {
    ak: localStorage.getItem("chipax_ak"),
    it: localStorage.getItem("chipax_it")
  };
}

function updateKeysStatus() {
  var k = getKeys();
  var el = document.getElementById("keys-status");
  if (k.ak && k.it) {
    el.textContent = "Credenciales configuradas";
    el.className = "keys-ok";
    document.getElementById("anthropic-key").value = "****************";
    document.getElementById("intercom-token").value = "****************";
  } else {
    el.textContent = "No configuradas";
    el.className = "keys-missing";
  }
}

function showAlert(msg, type) {
  var box = document.getElementById("alert-box");
  box.innerHTML = "<div class='alert alert-" + type + "'>" + msg + "</div>";
  if (type === "success") setTimeout(function() { box.innerHTML = ""; }, 3000);
}

function setStep(msg) {
  document.getElementById("step-msg").textContent = msg || "";
}

function setLoading(on) {
  var btn = document.getElementById("main-btn");
  btn.disabled = on;
  btn.textContent = on ? "Procesando..." : "Buscar articulos y analizar cambios";
}

function escHtml(s) {
  return String(s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function buscarArticulos(token) {
  return fetch("https://api.intercom.io/articles?per_page=20", {
    headers: { "Authorization": "Bearer " + token, "Accept": "application/json" }
  }).then(function(res) {
    if (!res.ok) throw new Error("Error al conectar con Intercom. Verifica el token.");
    return res.json();
  }).then(function(data) {
    return (data.data || []).map(function(a) {
      return {
        id: a.id,
        titulo: a.title || "",
        contenido: a.body ? a.body.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim() : ""
      };
    });
  });
}

function publicarArticulo(token, id, contenido) {
  return fetch("https://api.intercom.io/articles/" + id, {
    method: "PUT",
    headers: {
      "Authorization": "Bearer " + token,
      "Content-Type": "application/json",
      "Accept": "application/json"
    },
    body: JSON.stringify({ body: "<p>" + contenido.replace(/\n/g, "</p><p>") + "</p>" })
  }).then(function(res) {
    if (!res.ok) throw new Error("Error al publicar en Intercom.");
  });
}

function callClaude(ak, prompt) {
  return fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": ak,
      "anthropic-version": "2023-06-01",
      "anthropic-dangerous-direct-browser-access": "true"
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 4000,
      messages: [{ role: "user", content: prompt }]
    })
  }).then(function(res) {
    return res.json();
  }).then(function(data) {
    if (data.error) throw new Error(data.error.message);
    return (data.content || []).map(function(b) { return b.text || ""; }).join("");
  });
}

function run() {
  var cambio = document.getElementById("cambio").value.trim();
  var referencia = document.getElementById("referencia").value.trim();
  var keys = getKeys();
  if (!keys.ak || !keys.it) { showAlert("Primero guarda las credenciales.", "error"); return; }
  if (!cambio) { showAlert("Describe el cambio antes de continuar.", "error"); return; }

  document.getElementById("alert-box").innerHTML = "";
  document.getElementById("resultado").style.display = "none";
  setLoading(true);
  setStep("Conectando con Intercom...");

  buscarArticulos(keys.it).then(function(arts) {
    if (arts.length === 0) throw new Error("No se encontraron articulos en Intercom.");
    setStep(arts.length + " articulos encontrados. Analizando con Claude...");

    var artsTexto = arts.map(function(a) {
      return "--- ID:" + a.id + " | " + a.titulo + " ---\n" + a.contenido.slice(0, 600);
    }).join("\n\n");

    var refTexto = referencia ? "\n\nREFERENCIAS:\n" + referencia : "";

    var prompt = "Eres un editor experto del Help Center de Chipax, documentacion SaaS B2B.\n\n"
      + "CAMBIO INDICADO:\n" + cambio + refTexto + "\n\n"
      + "ARTICULOS EN INTERCOM:\n" + artsTexto + "\n\n"
      + "Analiza cada articulo. Aplica el cambio donde corresponda. Ignora los no relacionados.\n"
      + "Responde SOLO en JSON valido sin backticks con esta estructura exacta:\n"
      + "{\"resumen\":\"...\",\"criterio\":\"...\",\"aprobacion\":\"...\","
      + "\"articulos\":[{\"id\":\"...\",\"nombre\":\"...\",\"estado\":\"Actualizado\","
      + "\"motivo\":\"...\",\"cambios\":[\"...\"],\"version\":\"...\"}],"
      + "\"consistencia\":\"...\",\"riesgos\":\"...\"}\n\n"
      + "Estados validos: Actualizado, Actualizado parcialmente, Sin cambios.\n"
      + "Estilo Chipax: espanol claro, simple, directo, humano.";

    setStep("Claude esta analizando y editando los articulos...");
    return callClaude(keys.ak, prompt);

  }).then(function(raw) {
    var clean = raw.replace(/```json/g, "").replace(/```/g, "").trim();
    resultado = JSON.parse(clean);
    activeSection = "aprobacion";
    renderResultado();
    setStep("");

  }).catch(function(e) {
    showAlert(e.message || "Error inesperado.", "error");
    setStep("");

  }).finally(function() {
    setLoading(false);
  });
}

function renderResultado() {
  document.getElementById("resultado").style.display = "block";
  renderTabs();
  renderSection(activeSection);
  document.getElementById("resultado").scrollIntoView({ behavior: "smooth" });
}

function renderTabs() {
  var html = SECTIONS.map(function(s) {
    var cls = s === activeSection ? "tab active" : "tab";
    return "<button class='" + cls + "' onclick=\"switchTab('" + s + "')\">" + LABELS[s] + "</button>";
  }).join("");
  document.getElementById("tabs").innerHTML = html;
}

function switchTab(s) {
  activeSection = s;
  renderTabs();
  renderSection(s);
}

function renderSection(s) {
  var el = document.getElementById("tab-content");
  if (s !== "articulos") {
    el.innerHTML = "<p class='text-result'>" + escHtml(resultado[s] || "") + "</p>";
    return;
  }
  var arts = resultado.articulos || [];
  var html = arts.map(function(art, i) {
    var bc = art.estado === "Sin cambios" ? "badge-none"
      : art.estado === "Actualizado parcialmente" ? "badge-partial"
      : "badge-updated";
    var cambiosList = (art.cambios || []).map(function(c) {
      return "<li>" + escHtml(c) + "</li>";
    }).join("");
    var pubBtn = (art.estado !== "Sin cambios" && art.id)
      ? "<button class='btn-publish' onclick=\"publicar('" + art.id + "'," + i + ")\">Publicar en Intercom</button>"
      : "";
    var sep = i < arts.length - 1 ? "<hr class='art-sep'>" : "";
    return "<div>"
      + "<div class='art-header'>"
      + "<span class='art-title'>" + escHtml(art.nombre || ("Articulo " + (i + 1))) + "</span>"
      + "<span class='badge " + bc + "'>" + escHtml(art.estado) + "</span>"
      + pubBtn
      + "</div>"
      + "<p class='art-meta'><strong>Motivo:</strong> " + escHtml(art.motivo || "") + "</p>"
      + (cambiosList ? "<strong style='font-size:13px'>Cambios:</strong><ul class='changes-list'>" + cambiosList + "</ul>" : "")
      + (art.version ? "<strong style='font-size:13px'>Version actualizada:</strong><div class='version-box'>" + escHtml(art.version) + "</div>" : "")
      + "</div>" + sep;
  }).join("");
  el.innerHTML = html;
}

function publicar(id, idx) {
  var art = resultado.articulos[idx];
  if (!confirm("Publicar los cambios de " + art.nombre + " en Intercom?")) return;
  var keys = getKeys();
  publicarArticulo(keys.it, id, art.version).then(function() {
    showAlert("Articulo publicado en Intercom.", "success");
  }).catch(function(e) {
    showAlert("Error al publicar: " + e.message, "error");
  });
}

updateKeysStatus();
</script>
</body>
</html>
